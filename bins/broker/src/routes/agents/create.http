@base = http://localhost:8080
@tenant_id = 775a179d-9819-42c0-ab47-637bf96fbf7b

### Create Calendar Agent
POST {{base}}/agents HTTP/1.1
content-type: application/json

{
    "tenant_id": "{{tenant_id}}",
    "name": "calendar_agent",
    "description": "Manages calendars, availability, meetings, attendees, and reminders",
    "skills": [
        {
            "name": "manage_calendar",
            "display_name": "Manage Calendar"
        },
        {
            "name": "check_availability",
            "display_name": "Check Availability"
        },
        {
            "name": "schedule_meeting",
            "display_name": "Schedule Meeting"
        }
    ]
}

### Create Expense Agent
POST {{base}}/agents HTTP/1.1
content-type: application/json

{
